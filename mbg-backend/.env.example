# ── Supabase (Dashboard → Project Settings → API) ──
SUPABASE_URL=https://xxxxxxxx.supabase.co
# service_role key — backend ONLY, bypass RLS. JANGAN pernah ditaruh di frontend.
SUPABASE_SERVICE_KEY=eyJ...service_role...

# ── Qwen / DashScope (Alibaba Cloud Model Studio) ──
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxx
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# ── Auth JWT ──
# WAJIB diganti dengan string acak panjang. Generate: `openssl rand -hex 32`
JWT_SECRET=ganti-dengan-string-acak-panjang
JWT_EXPIRE_HOURS=12

# ── URL Frontend ──
# Lokal: http://localhost:3000
# Produksi: isi dengan domain Vercel, ex: https://mbgku.vercel.app
FRONTEND_ORIGIN=http://localhost:3000   # CORS — origin yang diizinkan
BASE_URL=http://localhost:3000          # dipakai untuk encode URL di dalam QR
